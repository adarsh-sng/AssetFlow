generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EmployeeRole {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AllocationTargetType {
  EMPLOYEE
  DEPARTMENT
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  TRANSFERRED
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
  CANCELLED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum AuditStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum AuditItemStatus {
  PENDING
  VERIFIED
  MISSING
  DAMAGED
}

enum NotificationType {
  ASSET
  BOOKING
  MAINTENANCE
  TRANSFER
  AUDIT
  OVERDUE
  SYSTEM
}

enum ActivityEntityType {
  EMPLOYEE
  DEPARTMENT
  ASSET_CATEGORY
  ASSET
  ALLOCATION
  TRANSFER
  BOOKING
  MAINTENANCE
  AUDIT
  NOTIFICATION
}

model Employee {
  id                   String               @id @default(cuid())
  name                 String
  email                String               @unique
  passwordHash         String
  role                 EmployeeRole         @default(EMPLOYEE)
  status               RecordStatus         @default(ACTIVE)
  departmentId         String?
  department           Department?          @relation("DepartmentMembers", fields: [departmentId], references: [id], onDelete: SetNull)
  headedDepartments    Department[]         @relation("DepartmentHeads")
  requestedTransfers   TransferRequest[]    @relation("TransferRequester")
  approvedTransfers    TransferRequest[]    @relation("TransferApprover")
  targetTransfers      TransferRequest[]    @relation("TransferToEmployee")
  employeeAllocations  AssetAllocation[]    @relation("EmployeeAllocations")
  createdAllocations   AssetAllocation[]    @relation("AllocationCreator")
  requestedMaintenance MaintenanceRequest[] @relation("MaintenanceRequester")
  approvedMaintenance  MaintenanceRequest[] @relation("MaintenanceApprover")
  technicianJobs       MaintenanceRequest[] @relation("MaintenanceTechnician")
  bookings             ResourceBooking[]    @relation("BookingRequester")
  assignedAudits       AuditAssignment[]
  verifiedAuditItems   AuditItem[]          @relation("AuditVerifier")
  notifications        Notification[]
  activityLogs         ActivityLog[]        @relation("ActivityActor")
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([departmentId])
  @@index([role])
  @@index([status])
}

model Department {
  id              String            @id @default(cuid())
  name            String            @unique
  status          RecordStatus      @default(ACTIVE)
  parentId        String?
  parent          Department?       @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children        Department[]      @relation("DepartmentHierarchy")
  headId          String?
  head            Employee?         @relation("DepartmentHeads", fields: [headId], references: [id], onDelete: SetNull)
  employees       Employee[]        @relation("DepartmentMembers")
  assets          Asset[]
  allocations     AssetAllocation[] @relation("DepartmentAllocations")
  targetTransfers TransferRequest[] @relation("TransferToDepartment")
  auditCycles     AuditCycle[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([parentId])
  @@index([headId])
  @@index([status])
}

model AssetCategory {
  id              String       @id @default(cuid())
  name            String       @unique
  description     String?
  status          RecordStatus @default(ACTIVE)
  customFields    Json?
  defaultBookable Boolean      @default(false)
  assets          Asset[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([status])
}

model Asset {
  id                  String               @id @default(cuid())
  tag                 String               @unique
  name                String
  serialNumber        String?              @unique
  qrCode              String?              @unique
  status              AssetStatus          @default(AVAILABLE)
  condition           String?
  location            String?
  acquisitionDate     DateTime?
  acquisitionCost     Decimal?             @db.Decimal(12, 2)
  warrantyExpiresAt   DateTime?
  retirementDueAt     DateTime?
  isBookable          Boolean              @default(false)
  photoUrl            String?
  documentUrl         String?
  categoryId          String
  category            AssetCategory        @relation(fields: [categoryId], references: [id])
  departmentId        String?
  department          Department?          @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  allocations         AssetAllocation[]
  transferRequests    TransferRequest[]
  bookings            ResourceBooking[]
  maintenanceRequests MaintenanceRequest[]
  auditItems          AuditItem[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([categoryId])
  @@index([departmentId])
  @@index([status])
  @@index([location])
}

model AssetAllocation {
  id                 String               @id @default(cuid())
  assetId            String
  asset              Asset                @relation(fields: [assetId], references: [id], onDelete: Cascade)
  targetType         AllocationTargetType
  employeeId         String?
  employee           Employee?            @relation("EmployeeAllocations", fields: [employeeId], references: [id], onDelete: SetNull)
  departmentId       String?
  department         Department?          @relation("DepartmentAllocations", fields: [departmentId], references: [id], onDelete: SetNull)
  status             AllocationStatus     @default(ACTIVE)
  allocatedAt        DateTime             @default(now())
  expectedReturnAt   DateTime?
  returnedAt         DateTime?
  checkOutNotes      String?
  checkInNotes       String?
  returnCondition    String?
  createdById        String?
  createdBy          Employee?            @relation("AllocationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  outgoingTransfers  TransferRequest[]    @relation("TransferFromAllocation")
  resultingTransfers TransferRequest[]    @relation("TransferResultAllocation")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([assetId, status])
  @@index([employeeId])
  @@index([departmentId])
  @@index([expectedReturnAt])
}

model TransferRequest {
  id                    String               @id @default(cuid())
  assetId               String
  asset                 Asset                @relation(fields: [assetId], references: [id], onDelete: Cascade)
  fromAllocationId      String?
  fromAllocation        AssetAllocation?     @relation("TransferFromAllocation", fields: [fromAllocationId], references: [id], onDelete: SetNull)
  toTargetType          AllocationTargetType
  toEmployeeId          String?
  toEmployee            Employee?            @relation("TransferToEmployee", fields: [toEmployeeId], references: [id], onDelete: SetNull)
  toDepartmentId        String?
  toDepartment          Department?          @relation("TransferToDepartment", fields: [toDepartmentId], references: [id], onDelete: SetNull)
  reason                String
  status                TransferStatus       @default(REQUESTED)
  requestedById         String?
  requestedBy           Employee?            @relation("TransferRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  approvedById          String?
  approvedBy            Employee?            @relation("TransferApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  resultingAllocationId String?
  resultingAllocation   AssetAllocation?     @relation("TransferResultAllocation", fields: [resultingAllocationId], references: [id], onDelete: SetNull)
  decidedAt             DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([assetId])
  @@index([status])
  @@index([requestedById])
  @@index([approvedById])
}

model ResourceBooking {
  id            String        @id @default(cuid())
  assetId       String
  asset         Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  requestedById String?
  requestedBy   Employee?     @relation("BookingRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  title         String
  status        BookingStatus @default(UPCOMING)
  startsAt      DateTime
  endsAt        DateTime
  location      String?
  notes         String?
  reminderAt    DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([assetId, startsAt, endsAt])
  @@index([requestedById])
  @@index([status])
}

model MaintenanceRequest {
  id             String              @id @default(cuid())
  assetId        String
  asset          Asset               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  issue          String
  description    String?
  priority       MaintenancePriority @default(MEDIUM)
  status         MaintenanceStatus   @default(PENDING)
  attachmentUrl  String?
  requestedById  String?
  requestedBy    Employee?           @relation("MaintenanceRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  approvedById   String?
  approvedBy     Employee?           @relation("MaintenanceApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  technicianId   String?
  technician     Employee?           @relation("MaintenanceTechnician", fields: [technicianId], references: [id], onDelete: SetNull)
  approvedAt     DateTime?
  startedAt      DateTime?
  resolvedAt     DateTime?
  resolutionNote String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([assetId])
  @@index([status])
  @@index([priority])
  @@index([requestedById])
}

model AuditCycle {
  id           String            @id @default(cuid())
  name         String
  status       AuditStatus       @default(DRAFT)
  scope        String
  departmentId String?
  department   Department?       @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  location     String?
  startsAt     DateTime
  endsAt       DateTime
  closedAt     DateTime?
  assignments  AuditAssignment[]
  items        AuditItem[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([departmentId])
  @@index([status])
  @@index([startsAt, endsAt])
}

model AuditAssignment {
  id         String     @id @default(cuid())
  auditId    String
  audit      AuditCycle @relation(fields: [auditId], references: [id], onDelete: Cascade)
  auditorId  String
  auditor    Employee   @relation(fields: [auditorId], references: [id], onDelete: Cascade)
  assignedAt DateTime   @default(now())

  @@unique([auditId, auditorId])
  @@index([auditorId])
}

model AuditItem {
  id               String          @id @default(cuid())
  auditId          String
  audit            AuditCycle      @relation(fields: [auditId], references: [id], onDelete: Cascade)
  assetId          String
  asset            Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  expectedLocation String?
  actualLocation   String?
  status           AuditItemStatus @default(PENDING)
  notes            String?
  verifiedById     String?
  verifiedBy       Employee?       @relation("AuditVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)
  verifiedAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([auditId, assetId])
  @@index([assetId])
  @@index([status])
  @@index([verifiedById])
}

model Notification {
  id          String              @id @default(cuid())
  recipientId String?
  recipient   Employee?           @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  type        NotificationType
  title       String
  message     String
  entityType  ActivityEntityType?
  entityId    String?
  readAt      DateTime?
  createdAt   DateTime            @default(now())

  @@index([recipientId])
  @@index([type])
  @@index([readAt])
}

model ActivityLog {
  id          String             @id @default(cuid())
  actorId     String?
  actor       Employee?          @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  action      String
  entityType  ActivityEntityType
  entityId    String
  description String
  metadata    Json?
  createdAt   DateTime           @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
